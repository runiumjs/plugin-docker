{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "esnext",
    "outDir": "./lib",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "module": "esnext",
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": false,
    "strictNullChecks": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "@runium/types-plugin"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
